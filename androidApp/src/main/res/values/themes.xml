<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Splash theme: applied to the launcher activity. AndroidX core-splashscreen
        backports this behavior to API 23+. We make the OS-level splash invisible
        (transparent icon, white background that matches the in-app splash) and
        kill the exit animation in MainActivity, so the user only sees the
        custom Compose SplashScreen choreography.

        postSplashScreenTheme is the theme the activity adopts once
        installSplashScreen() dismisses the splash — the original app theme.
    -->
    <style name="Theme.MyKitta.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="postSplashScreenTheme">@android:style/Theme.Material.Light.NoActionBar</item>
    </style>
</resources>
