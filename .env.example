# MyKitta build-time configuration.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The :shared:generateBuildEnv Gradle task reads this at build time and emits
# `FlavorConfig.kt` into commonMain. If `.env` is missing or any required key
# is absent the build fails loudly.

# Base URLs per (flavor × country). Each country is a separate backend, so the
# request URL is chosen at call time based on the user's selected country.
BASE_URL_DEV_PH=https://dev-ph.mykitta.example/api/
BASE_URL_DEV_SG=https://dev-sg.mykitta.example/api/
BASE_URL_STAGING_PH=https://staging-ph.mykitta.example/api/
BASE_URL_STAGING_SG=https://staging-sg.mykitta.example/api/
BASE_URL_PROD_PH=https://api-ph.mykitta.example/api/
BASE_URL_PROD_SG=https://api-sg.mykitta.example/api/

# App display name per flavor.
APP_NAME_DEV="MyKitta Dev"
APP_NAME_STAGING="MyKitta Staging"
APP_NAME_PROD="MyKitta"
