<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!--
		App Transport Security exception for the legacy B2B-SIMPLR backend, which
		serves over plain HTTP. Targeted to specific domains rather than
		NSAllowsArbitraryLoads = true, so the policy stays tight for everything
		else. Add another <key>domain</key>...<dict>...</dict> pair when the SG
		backend is provisioned, or migrate the backend to HTTPS and remove this.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>simplronline.in</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
