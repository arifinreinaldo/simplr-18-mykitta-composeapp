TEAM_ID=

PRODUCT_NAME=MyKitta
PRODUCT_BUNDLE_IDENTIFIER=com.simplr.mykitta2.MyKitta$(TEAM_ID)

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// MUST match the -mios-version-min flag in shared/build.gradle.kts. Drifting
// either side re-triggers "object file built for newer iOS-simulator version
// than being linked". iOS 15.0 covers iPhone 6s onwards (incl. iPhone 11).
IPHONEOS_DEPLOYMENT_TARGET = 15.0

// SQLDelight's NativeSqliteDriver inside Shared.framework references libsqlite3.
// For static frameworks, Kotlin/Native's framework-level linkerOpts don't always
// flow to the consumer link step — Xcode needs to add -lsqlite3 at the iosApp
// link itself. Without this, the iosApp link fails with 31 _sqlite3_* undefined
// symbols even though the shared framework was built with -lsqlite3.
OTHER_LDFLAGS = $(inherited) -lsqlite3